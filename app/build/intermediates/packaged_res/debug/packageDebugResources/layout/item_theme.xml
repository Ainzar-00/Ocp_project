<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Left: ID badge -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="@color/ocp_light_green"
            app:cardElevation="0dp">

            <TextView
                android:id="@+id/tv_theme_id"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textColor="@color/ocp_dark_green"
                android:textStyle="bold"
                android:textSize="11sp" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Middle: nom + objectif -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_theme_nom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#1A1A2E"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_theme_objectif"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:textColor="#757575"
                android:textSize="13sp"
                android:maxLines="2"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Right: sync status icon -->
        <ImageView
            android:id="@+id/iv_sync_status"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="8dp"
            android:contentDescription="Sync status" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

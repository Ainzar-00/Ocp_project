<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Header card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/ocp_dark_green">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📚 Thèmes de Formation"
                android:textColor="@android:color/white"
                android:textSize="17sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/progress_theme"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:visibility="gone"
                android:indeterminateTint="@android:color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_theme"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ Ajouter"
                android:textColor="@color/ocp_dark_green"
                app:backgroundTint="@android:color/white"
                app:cornerRadius="20dp"
                style="@style/Widget.MaterialComponents.Button" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Empty state -->
    <TextView
        android:id="@+id/tv_empty_themes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="100dp"
        android:gravity="center"
        android:text="Aucun thème enregistré.\nAppuyez sur «+ Ajouter» pour commencer."
        android:textColor="#9E9E9E"
        android:textSize="15sp"
        android:visibility="gone" />

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_themes"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="80dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        android:paddingHorizontal="12dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>

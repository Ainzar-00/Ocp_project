<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Import Bilan FC"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/ocp_dark_green"
            android:layout_marginBottom="16dp" />

        <!-- File picker card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📁 Sélection du fichier Excel"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Colonnes requises : ENTITE, Mle, NOM, PRENOM, DIV, THEME, Mois, Objectifs pédagogiques, Formateur"
                    android:textSize="12sp"
                    android:textColor="#666"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btn_choisir_fichier"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="📂 CHOISIR UN FICHIER"
                    android:backgroundTint="@color/ocp_dark_green" />

                <TextView
                    android:id="@+id/tv_selected_file"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="#333"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/btn_charger"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="⬆️ CHARGER LES DONNÉES"
                    android:backgroundTint="#1565C0"
                    android:layout_marginTop="8dp"
                    android:enabled="false" />

                <ProgressBar
                    android:id="@+id/progress_import"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_import_result"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Stats card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊 Statistiques"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tv_enregistrements"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 enregistrement(s) en base"
                    android:textSize="14sp"
                    android:textColor="#333"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btn_nombre_enregistrements"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="🔢 NOMBRE D'ENREGISTREMENTS"
                    android:backgroundTint="#37474F"
                    android:textSize="12sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Test matricule card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔍 Tester une référence"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Saisir un matricule"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="8dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_matricule"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text" />
                </com.google.android.material.textfield.TextInputLayout>

                <Button
                    android:id="@+id/btn_tester_reference"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="TESTER RÉFÉRENCE"
                    android:backgroundTint="#E65100"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_resultat_test"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp"
                    android:padding="12dp"
                    android:background="#F5F5F5"
                    android:visibility="gone" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
